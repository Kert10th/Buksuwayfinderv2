# BukSU Wayfinder - Cloud sync (Cloudflare R2)
# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored and will NOT be committed.
#
# Cloud sync is OPTIONAL: if these are left blank, the app still works fully
# using localStorage + manual Export/Import. Set them only when you're ready
# to flip on cloud sync for your kiosks.

# Public read URL of the JSON object in your R2 bucket.
# Example: https://pub-abc123.r2.dev/wayfinder.json
VITE_R2_PUBLIC_URL=

# Your Cloudflare account ID (hex string, visible on the R2 page).
VITE_R2_ACCOUNT_ID=

# R2 API token: Access Key ID + Secret Access Key.
# Create one at: R2 → Manage R2 API Tokens → Create Token.
# Permission: "Admin Read & Write" scoped to the bucket below.
VITE_R2_ACCESS_KEY_ID=
VITE_R2_SECRET_KEY=

# Name of the bucket holding wayfinder.json.
VITE_R2_BUCKET=buksu-wayfinder

# Admin login password for the secret 5-tap login. Set to any strong string.
# On Cloudflare Pages, add this under Settings -> Environment variables.
# If unset, the app falls back to "admin123" (only use the fallback locally).
VITE_ADMIN_PASSWORD=
